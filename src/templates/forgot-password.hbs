{{!-- layout: main --}}
{{!-- headerTitle: tiêu đề header --}}
{{#> main}}
<h2 style="font-size:22px;color:#1f2937;margin:0 0 8px 0;font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;">
  Xin chào {{fullname}}, 👋
</h2>
<p style="color:#4b5563;font-size:15px;line-height:1.6;margin:0 0 20px 0;">Bạn đã yêu cầu đặt lại mật khẩu cho tài khoản Workout App của mình. Đừng lo lắng, chúng tôi sẽ giúp bạn quay lại phòng tập ngay!</p>

<!-- Plan box -->
<div style="background-color:#f9fafb;border-left:4px solid #4F46E5;padding:20px;margin:25px 0;border-radius:0 8px 8px 0;">
  <span style="font-size:18px;font-weight:bold;color:#4F46E5;margin-bottom:10px;display:block;">
    🔑 Thông tin yêu cầu
  </span>

  <table width="100%" cellpadding="0" cellspacing="0" border="0">
    <tr>
      <td style="padding:8px 0;border-bottom:1px dashed #e5e7eb;">
        <span style="color:#6b7280;font-size:14px;">📧 Tài khoản</span>
      </td>
      <td align="right" style="padding:8px 0;border-bottom:1px dashed #e5e7eb;">
        <span style="font-weight:600;color:#1f2937;">{{email_value}}</span>
      </td>
    </tr>
    <tr>
      <td style="padding:8px 0;">
        <span style="color:#6b7280;font-size:14px;">⏳ Hết hạn trong</span>
      </td>
      <td align="right" style="padding:8px 0;">
        <span style="font-weight:600;color:#ef4444;">{{expire_value}}</span>
      </td>
    </tr>
  </table>
</div>

<p style="color:#4b5563;font-size:14px;line-height:1.6;margin:0 0 30px 0;">Nếu bạn không thực hiện yêu cầu này, hãy bỏ qua email này. Tài khoản của bạn vẫn an toàn.</p>

<!-- Button -->
<table width="100%" cellpadding="0" cellspacing="0" border="0">
  <tr>
    <td align="center" style="padding-top:5px;">
      <a href="{{link}}"
         style="background-color:#4F46E5;color:#ffffff;padding:14px 30px;text-decoration:none;border-radius:8px;font-weight:bold;display:inline-block;font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;font-size:15px;">
        ĐẶT LẠI MẬT KHẨU NGAY
      </a>
    </td>
  </tr>
</table>
{{/main}}