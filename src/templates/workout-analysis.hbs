{{!-- layout: main --}}
{{!-- headerTitle, user.fullName, workout.*, disciplineAnalysis.*,
      volumeProgressAnalysis.note, intensityEvaluation.*,
      actionableTips[].tip --}}
{{#> main}}
<h2 style="font-size:20px;color:#2c3e50;text-align:center;border-bottom:2px solid #3498db;padding-bottom:10px;margin:0 0 20px 0;font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;">
  📊 Báo cáo phân tích tập luyện: {{user.fullName}}
</h2>

<!-- Workout detail -->
<div style="background:#f8f9fa;padding:15px;border-radius:8px;margin-bottom:20px;">
  <h3 style="margin:0 0 12px 0;color:#3498db;font-size:16px;font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;">
    🏋️ Chi tiết buổi tập: {{workout.name}}
  </h3>
  <table width="100%" cellpadding="0" cellspacing="0" border="0">
    <tr>
      <td style="padding:5px 0;color:#1f2937;font-size:14px;"><strong>Số bài tập:</strong></td>
      <td style="padding:5px 0;color:#4b5563;font-size:14px;">{{workout.numExercises}} bài</td>
    </tr>
    <tr>
      <td style="padding:5px 0;color:#1f2937;font-size:14px;"><strong>Thời gian:</strong></td>
      <td style="padding:5px 0;color:#4b5563;font-size:14px;">{{workout.duration}} giây</td>
    </tr>
    <tr>
      <td style="padding:5px 0;color:#1f2937;font-size:14px;"><strong>Calo ước tính:</strong></td>
      <td style="padding:5px 0;font-weight:bold;color:#e67e22;font-size:14px;">{{workout.estimatedCalories}} kcal</td>
    </tr>
  </table>
</div>

<!-- AI Analysis -->
<div style="margin-bottom:20px;">
  <h3 style="color:#2c3e50;border-left:4px solid #e74c3c;padding-left:10px;margin:0 0 16px 0;font-size:16px;font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;">
    💡 Phân tích chuyên sâu từ AI
  </h3>

  <div style="margin-bottom:15px;">
    <p style="margin:0 0 6px 0;font-size:14px;color:#1f2937;"><strong>🛡️ Độ kỷ luật ({{disciplineAnalysis.completionRate}}%):</strong></p>
    <p style="font-style:italic;color:#555;background:#fff5f5;padding:10px;border-radius:5px;font-size:14px;margin:0;line-height:1.6;">
      {{disciplineAnalysis.note}}
    </p>
  </div>

  <div style="margin-bottom:15px;">
    <p style="margin:0 0 6px 0;font-size:14px;color:#1f2937;"><strong>📈 Khối lượng (Volume):</strong></p>
    <p style="color:#555;font-size:14px;margin:0;line-height:1.6;">{{volumeProgressAnalysis.note}}</p>
  </div>

  <div style="margin-bottom:15px;">
    <p style="margin:0 0 6px 0;font-size:14px;color:#1f2937;"><strong>🔥 Cường độ (RPE tối ưu: {{intensityEvaluation.optimalRPERange}}):</strong></p>
    <p style="color:#555;font-size:14px;margin:0;line-height:1.6;">{{intensityEvaluation.note}}</p>
  </div>
</div>

<!-- Tips -->
<div style="background:#e8f4fd;padding:15px;border-radius:8px;margin-bottom:20px;">
  <h3 style="margin:0 0 10px 0;color:#2980b9;font-size:16px;font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;">
    🚀 Lời khuyên dành riêng cho bạn:
  </h3>
  <ul style="padding-left:20px;margin:0;color:#1f2937;font-size:14px;line-height:1.8;">
    {{#each actionableTips}}
      <li style="margin-bottom:8px;">{{this.tip}}</li>
    {{/each}}
  </ul>
</div>

<p style="font-size:12px;color:#95a5a6;text-align:center;margin:0;line-height:1.6;">
  Báo cáo này được tạo tự động bởi AI dựa trên dữ liệu tập luyện của bạn.<br>
  Hãy duy trì tập luyện đều đặn để đạt mục tiêu nhé!
</p>
{{/main}}