{{!-- layout: main --}}
{{!-- headerTitle, hello, fullname, head_description, name,
      start_Date, startDate, end_Date, endDate,
      num_Exercises, numExercises, ex,
      calories, estimatedCalories,
      footer_description, link, details --}}
{{#> main}}
<h2 style="font-size:22px;color:#1f2937;margin:0 0 8px 0;font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;">
  {{hello}} {{fullname}}, 💪
</h2>
<p style="color:#4b5563;font-size:15px;line-height:1.6;margin:0 0 20px 0;">{{head_description}}</p>

<!-- Plan box -->
<div style="background-color:#f9fafb;border-left:4px solid #4F46E5;padding:20px;margin:25px 0;border-radius:0 8px 8px 0;">
  <span style="font-size:18px;font-weight:bold;color:#4F46E5;margin-bottom:12px;display:block;">{{name}}</span>

  <table width="100%" cellpadding="0" cellspacing="0" border="0">
    <tr>
      <td style="padding:8px 0;border-bottom:1px dashed #e5e7eb;">
        <span style="color:#6b7280;font-size:14px;">📅 {{start_Date}}</span>
      </td>
      <td align="right" style="padding:8px 0;border-bottom:1px dashed #e5e7eb;">
        <span style="font-weight:600;color:#1f2937;">{{formatDate startDate}}</span>
      </td>
    </tr>
    <tr>
      <td style="padding:8px 0;border-bottom:1px dashed #e5e7eb;">
        <span style="color:#6b7280;font-size:14px;">🏁 {{end_Date}}</span>
      </td>
      <td align="right" style="padding:8px 0;border-bottom:1px dashed #e5e7eb;">
        <span style="font-weight:600;color:#1f2937;">{{formatDate endDate}}</span>
      </td>
    </tr>
    <tr>
      <td style="padding:8px 0;border-bottom:1px dashed #e5e7eb;">
        <span style="color:#6b7280;font-size:14px;">🏋️ {{num_Exercises}}</span>
      </td>
      <td align="right" style="padding:8px 0;border-bottom:1px dashed #e5e7eb;">
        <span style="font-weight:600;color:#1f2937;">{{numExercises}} {{ex}}</span>
      </td>
    </tr>
    <tr>
      <td style="padding:8px 0;">
        <span style="color:#6b7280;font-size:14px;">🔥 {{calories}}</span>
      </td>
      <td align="right" style="padding:8px 0;">
        <span style="font-weight:600;color:#4F46E5;">{{estimatedCalories}} kcal</span>
      </td>
    </tr>
  </table>
</div>

<p style="color:#4b5563;font-size:14px;line-height:1.6;margin:0 0 30px 0;">{{footer_description}}</p>

<!-- Button -->
<table width="100%" cellpadding="0" cellspacing="0" border="0">
  <tr>
    <td align="center">
      <a href="{{link}}"
         style="background-color:#4F46E5;color:#ffffff;padding:14px 30px;text-decoration:none;border-radius:8px;font-weight:bold;display:inline-block;font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;font-size:15px;">
        {{details}}
      </a>
    </td>
  </tr>
</table>
{{/main}}