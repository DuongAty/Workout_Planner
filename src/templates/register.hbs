{{!-- layout: main --}}
{{!-- headerTitle, hello, fullname, welcome_text, email, welcome_text2, loginUrl, login, contact, footerText --}}
{{#> main}}
<div style="text-align:center;">
  <span style="font-size:60px;margin-bottom:20px;display:block;">🎉</span>

  <h2 style="font-size:22px;color:#1f2937;margin:0 0 12px 0;font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;">
  {{hello}} {{fullname}}
  </h2>

  <p style="line-height:1.6;color:#4b5563;font-size:15px;margin:0 0 20px 0;">
    {{welcome_text}}
  </p>

  <!-- Info box -->
  <div style="background-color:#f9fafb;border:1px dashed #4F46E5;padding:20px;margin:25px 0;border-radius:12px;text-align:left;">
    <p style="margin:5px 0;color:#4b5563;font-size:14px;">
      📧 <strong>Email:</strong>
      <span style="color:#4F46E5;font-weight:bold;">{{email}}</span>
    </p>
  </div>

  <p style="line-height:1.6;color:#4b5563;font-size:15px;margin:0 0 30px 0;">
    {{welcome_text2}}
  </p>

  <!-- Button -->
  <table width="100%" cellpadding="0" cellspacing="0" border="0">
    <tr>
      <td align="center">
        <a href="{{loginUrl}}"
           style="background-color:#4F46E5;color:#ffffff;padding:14px 35px;text-decoration:none;border-radius:8px;font-weight:bold;display:inline-block;font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;font-size:15px;">
          {{login}}
        </a>
      </td>
    </tr>
  </table>

  <p style="margin-top:30px;font-size:13px;color:#9ca3af;font-style:italic;">
    {{contact}}
  </p>
</div>
{{/main}}