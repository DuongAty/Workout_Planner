{{!-- layout: main --}}
{{!-- headerTitle, fullname, data.*, aiAnalysis.* --}}
{{#> main}}
<h2 style="font-size:22px;color:#1f2937;margin:0 0 8px 0;font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;">
  Chào {{fullname}}, 💪
</h2>
<p style="color:#4b5563;font-size:15px;line-height:1.6;margin:0 0 20px 0;">
  Chúc mừng bạn đã hoàn thành một tháng nỗ lực. Dưới đây là bảng tổng kết chi tiết.
</p>

<!-- Stats grid (dùng table cho Gmail) -->
<table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:20px 0;">
  <tr>
    <td width="48%" style="background-color:#f9fafb;padding:15px;border-radius:12px;border:1px solid #e5e7eb;text-align:center;vertical-align:top;">
      <span style="display:block;font-size:18px;font-weight:bold;color:#4F46E5;">{{data.totalWorkouts}}</span>
      <span style="font-size:11px;color:#6b7280;text-transform:uppercase;margin-top:4px;display:block;">Tổng buổi tập</span>
    </td>
    <td width="4%"></td>
    <td width="48%" style="background-color:#f9fafb;padding:15px;border-radius:12px;border:1px solid #e5e7eb;text-align:center;vertical-align:top;">
      <span style="display:block;font-size:18px;font-weight:bold;color:#4F46E5;">{{data.estimatedCalories}} kcal</span>
      <span style="font-size:11px;color:#6b7280;text-transform:uppercase;margin-top:4px;display:block;">Năng lượng tiêu thụ</span>
    </td>
  </tr>
  <tr><td colspan="3" style="padding:6px 0;"></td></tr>
  <tr>
    <td width="48%" style="background-color:#f9fafb;padding:15px;border-radius:12px;border:1px solid #e5e7eb;text-align:center;vertical-align:top;">
      <span style="display:block;font-size:18px;font-weight:bold;color:#4F46E5;">{{roundNumber aiAnalysis.summary.workoutFrequencyPerWeek}} buổi/tuần</span>
      <span style="font-size:11px;color:#6b7280;text-transform:uppercase;margin-top:4px;display:block;">Tần suất trung bình</span>
    </td>
    <td width="4%"></td>
    <td width="48%" style="background-color:#f9fafb;padding:15px;border-radius:12px;border:1px solid #e5e7eb;text-align:center;vertical-align:top;">
      <span style="display:block;font-size:18px;font-weight:bold;color:#4F46E5;">{{formatMinutes data.totalDuration}} phút</span>
      <span style="font-size:11px;color:#6b7280;text-transform:uppercase;margin-top:4px;display:block;">Tổng thời gian</span>
    </td>
  </tr>
  <tr><td colspan="3" style="padding:6px 0;"></td></tr>
  <tr>
    <td width="48%" style="background-color:#f9fafb;padding:15px;border-radius:12px;border:1px solid #e5e7eb;text-align:center;vertical-align:top;">
      <span style="display:block;font-size:18px;font-weight:bold;color:#4F46E5;">{{formatMinutes aiAnalysis.summary.averageWorkoutDurationMinutes}} phút</span>
      <span style="font-size:11px;color:#6b7280;text-transform:uppercase;margin-top:4px;display:block;">Trung bình/buổi</span>
    </td>
    <td width="4%"></td>
    <td width="48%" style="background-color:#f9fafb;padding:15px;border-radius:12px;border:1px solid #e5e7eb;text-align:center;vertical-align:top;">
      <span style="display:block;font-size:18px;font-weight:bold;color:#4F46E5;">{{data.totalExercises}} bài</span>
      <span style="font-size:11px;color:#6b7280;text-transform:uppercase;margin-top:4px;display:block;">Tổng số bài tập</span>
    </td>
  </tr>
  <tr><td colspan="3" style="padding:6px 0;"></td></tr>
  <tr>
    <td colspan="3" style="background-color:#f9fafb;padding:15px;border-radius:12px;border:1px solid #e5e7eb;text-align:center;vertical-align:top;">
      <span style="display:block;font-size:18px;font-weight:bold;color:#4F46E5;">{{aiAnalysis.summary.activityLevel}}</span>
      <span style="font-size:11px;color:#6b7280;text-transform:uppercase;margin-top:4px;display:block;">Mức độ hoạt động</span>
    </td>
  </tr>
</table>

<!-- AI Analysis box -->
<div style="background-color:#f0fdf4;border-left:4px solid #10b981;padding:20px;margin:25px 0;border-radius:0 8px 8px 0;">
  <p style="margin:0;font-weight:bold;color:#065f46;font-size:14px;">📊 Nhận xét từ chuyên gia AI:</p>
  <p style="margin:10px 0 0 0;font-style:italic;color:#374151;line-height:1.5;font-size:14px;">
    "{{aiAnalysis.analysis}}"
  </p>
</div>

<h3 style="font-size:18px;color:#1f2937;border-bottom:2px solid #f3f4f6;padding-bottom:8px;margin:20px 0 12px 0;font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;">
  💡 Lời khuyên cho tháng tới
</h3>
<ul style="padding-left:20px;color:#4b5563;line-height:1.8;font-size:14px;margin:0;">
  {{#each aiAnalysis.improvementSuggestions}}
    <li>{{this}}</li>
  {{/each}}
</ul>
{{/main}}